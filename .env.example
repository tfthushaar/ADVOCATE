# ── LLM Provider API Keys ────────────────────────────────────────────────────
# Set whichever providers you want to use. At least one is required.

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Google Gemini API key — get from https://aistudio.google.com/app/apikey
# Key format starts with "AIza..." — NOT an OAuth token
GOOGLE_API_KEY=your_google_api_key_here

# ── Default model (used when no model is explicitly specified) ────────────────
# Options: gpt-4o | gpt-4o-mini | gpt-4-turbo
#          claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
#          gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
ADVOCATE_MODEL=gpt-4o

# ── Infrastructure ────────────────────────────────────────────────────────────
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
# Free token — register at https://www.courtlistener.com/sign-in/ then copy from your profile
COURTLISTENER_API_TOKEN=your_courtlistener_token_here
CHROMA_PERSIST_PATH=./advocate/data/chroma_db
RULE_VALIDITY_THRESHOLD=0.75
